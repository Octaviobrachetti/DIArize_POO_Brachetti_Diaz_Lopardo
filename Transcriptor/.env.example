# Copia este archivo como .env y completa los valores
# El .env NO se sube a git (esta en .gitignore)

# Token de HuggingFace para diarizacion (gratis)
# https://huggingface.co/settings/tokens
# Aceptar terminos en https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=hf_tu_token_aqui

# API key de OpenAI para resumen/limpieza/analisis/Q&A
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu_key_aqui

# Modelo de OpenAI a usar (opcional, default gpt-4o-mini que es barato y bueno)
OPENAI_MODEL=gpt-4o-mini
