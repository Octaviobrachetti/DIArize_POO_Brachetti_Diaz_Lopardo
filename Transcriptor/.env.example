# Copia este archivo como .env y completa los valores
# El .env NO se sube a git (esta en .gitignore)

# === REQUERIDO ===
# API key de AssemblyAI para transcripcion + diarizacion en la nube
# Gratis en https://www.assemblyai.com (no requiere tarjeta de credito)
ASSEMBLYAI_API_KEY=tu_key_aqui

# === OPCIONAL ===
# API key de OpenAI para resumen/limpieza/analisis/Q&A en las tabs de IA
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo de OpenAI a usar (default: gpt-4o-mini, barato y preciso)
OPENAI_MODEL=gpt-4o-mini

# === SOLO PIPELINE LOCAL (no necesario con AssemblyAI) ===
# Token de HuggingFace para diarizacion local con PyAnnote
# HF_TOKEN=hf_tu_token_aqui
